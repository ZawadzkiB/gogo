# OS / editor cruft
.DS_Store
*.log

# Local-only Claude Code settings (not part of the published plugin)
.claude/settings.local.json

# NOTE: assets/mermaid/mermaid.min.js IS vendored on purpose — do not ignore it.

# JetBrains IDE project files (local only)
.idea/
*.iml

# Regenerable per-project gogo runtime: the vendored mermaid COPY, the viewer
# asset copies, and generated /gogo:view pages. Source of truth is assets/mermaid/
# + assets/viewer/ (committed); these are reproduced on demand by gogo commands.
.gogo/resources/

# Playwright MCP working dir (test tooling scratch — page snapshots, layout)
.playwright-mcp/

# Python bytecode cache — assets/xplan-board/server.py is vendored source; the
# .pyc it compiles to on run is regenerable and must never be committed.
__pycache__/
*.pyc

# /gogo:xplan React board: node_modules is a DEV-TIME install only. The BUILT
# dist/ (assets/xplan-board/dist/) IS committed on purpose so plugin users need
# no npm at runtime (D4=A) — do NOT ignore it.
assets/xplan-board/node_modules/

# Internal roadmap — local backlog, not part of the published plugin
roadmap.md
