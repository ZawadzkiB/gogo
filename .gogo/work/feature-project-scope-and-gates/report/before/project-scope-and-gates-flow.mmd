flowchart TD
  subgraph home["~/.gogo/  (CLI-owned data) — TODAY"]
    proj["project (name = repo basename)\nconfig.json  [no .knowledge/, no plans dir until first plan]"]
    plan["plan-XXXX.md\ndraft → ready → active → done  (nothing sets done)"]
    proj --> plan
  end

  add["gogo project add <repo>\nREQUIRES <repo>/.gogo/  (errors 'has no .gogo/')"]
  add --> proj

  subgraph srcA[".gogo/ in repo A  (skill-owned pipeline)"]
    wiA["work item a\nstate.md"]
    gA1{{"plan-accept gate\n(always, manual)"}}
    gA2{{"UAT gate\nawaiting-uat (always, manual /gogo:done)"}}
    wiA --> gA1 --> gA2 --> shipA["shipped"]
  end
  subgraph srcB[".gogo/ in repo B"]
    wiB["work item b"]
    gB1{{"plan-accept gate"}}
    gB2{{"UAT gate"}}
    wiB --> gB1 --> gB2 --> shipB["shipped"]
  end

  plan -- "/gogo:plan --correlation plan-XXXX" --> wiA
  plan -- "spawn (correlation)" --> wiB

  shipA -. "no project-level gate today" .-> gap["(plan stays 'active' —\nno project-UAT, no auto-done)"]
  shipB -. .-> gap

  classDef cli fill:#e8ecff,stroke:#7c8bd9,color:#111
  classDef skill fill:#fff3d6,stroke:#caa54a,color:#111
  classDef gap fill:#f3d6d6,stroke:#c07a7a,color:#111
  class home,proj,plan,add cli
  class srcA,srcB,wiA,wiB,gA1,gA2,gB1,gB2,shipA,shipB skill
  class gap gap
